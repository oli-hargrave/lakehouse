{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-southeastau-dev"
		},
		"LS_BUNDG01_MSSQL_CRM_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_BUNDG01_MSSQL_CRM'"
		},
		"LS_BUNDG01_MSSQL_PROPOSITO_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_BUNDG01_MSSQL_PROPOSITO'"
		},
		"LS_ADLSGEN2_INGEST_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://ingestionstprod.dfs.core.windows.net/"
		},
		"LS_BUNDG01_MSSQL_CRM_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "BUNDG01\\SQLEXPRESS"
		},
		"LS_BUNDG01_MSSQL_CRM_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "CRM"
		},
		"LS_BUNDG01_MSSQL_CRM_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "azure_login"
		},
		"LS_BUNDG01_MSSQL_PROPOSITO_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "BUNDG01"
		},
		"LS_BUNDG01_MSSQL_PROPOSITO_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "Proposito"
		},
		"LS_BUNDG01_MSSQL_PROPOSITO_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "azure_login"
		},
		"SHIR-BUNDG01-LNK_properties_typeProperties_linkedInfo_resourceId": {
			"type": "string",
			"defaultValue": "/subscriptions/e1798b20-5400-47cd-8a63-96cbeb75a685/resourcegroups/rg-adf-prod/providers/Microsoft.DataFactory/factories/adf-runtimes-southeastau-prod/integrationruntimes/SHIR-BUNDG01"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-southeastau-dev_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_BUNDG01_MSSQL_CRM_password": {
						"value": "[parameters('LS_BUNDG01_MSSQL_CRM_password')]"
					},
					"LS_BUNDG01_MSSQL_PROPOSITO_password": {
						"value": "[parameters('LS_BUNDG01_MSSQL_PROPOSITO_password')]"
