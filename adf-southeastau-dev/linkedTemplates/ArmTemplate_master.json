					"LS_BUNDG01_MSSQL_CRM_properties_typeProperties_server": {
						"value": "[parameters('LS_BUNDG01_MSSQL_CRM_properties_typeProperties_server')]"
					},
					"LS_BUNDG01_MSSQL_CRM_properties_typeProperties_database": {
						"value": "[parameters('LS_BUNDG01_MSSQL_CRM_properties_typeProperties_database')]"
					},
					"LS_BUNDG01_MSSQL_CRM_properties_typeProperties_userName": {
						"value": "[parameters('LS_BUNDG01_MSSQL_CRM_properties_typeProperties_userName')]"
					},
					"LS_BUNDG01_MSSQL_PROPOSITO_properties_typeProperties_server": {
						"value": "[parameters('LS_BUNDG01_MSSQL_PROPOSITO_properties_typeProperties_server')]"
					},
					"LS_BUNDG01_MSSQL_PROPOSITO_properties_typeProperties_database": {
						"value": "[parameters('LS_BUNDG01_MSSQL_PROPOSITO_properties_typeProperties_database')]"
					},
					"LS_BUNDG01_MSSQL_PROPOSITO_properties_typeProperties_userName": {
						"value": "[parameters('LS_BUNDG01_MSSQL_PROPOSITO_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
